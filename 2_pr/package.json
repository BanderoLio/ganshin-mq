{
  "name": "rabbit-redis-benchmark",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "consumer": "tsx src/consumer.ts",
    "ingest": "tsx src/ingest-api.ts",
    "benchmark:once": "tsx src/run-benchmarks.ts --broker rabbit --payload 1024 --rate 1000 --duration 30s",
    "benchmark:full": "tsx src/run-benchmarks.ts --full",
    "report:generate": "tsx src/generate-report.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down -v"
  },
  "dependencies": {
    "amqplib": "^0.10.8",
    "express": "^5.1.0",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
